# YouTube Streaming Configuration
# Copy this file to .env and fill in the values

# 1. YouTube RTMP Ingest URL (Default is usually correct)
YOUTUBE_URL=rtmp://a.rtmp.youtube.com/live2

# 2. YouTube Stream Key (Find this in YouTube Studio)
# DO NOT include the "/" at the start.
YOUTUBE_STREAM_KEY=your_stream_key_here

# 3. Local Ingest Name (Internal use only)
# This is NOT your YouTube title. Set your title in YouTube Studio.
# This name is used for the local mockup: http://localhost:8081/hls/[STREAM_NAME].m3u8
STREAM_NAME=test

# 4. Media selection
IMAGE_FILE=background.png

# 5. Video Settings
VIDEO_BITRATE=3000k
FRAMERATE=30
